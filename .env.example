# Copy this file to .env and fill in your real values

# Apify API token — https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Notion integration secret — https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_secret_here

# The Notion database ID where jobs will be written
# Get it from the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=9be73129ef2b4516a764caad9ceff043

# Anthropic API key for Claude Haiku resume optimisation
ANTHROPIC_API_KEY=your_anthropic_api_key_here
